rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActive() {
      return hasProfile()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    function isAdmin() {
      return isActive()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isBootstrapAdmin() {
      return signedIn()
        && request.auth.token.email in ["jeromeitable37@gmail.com", "jerometable37@gmail.com"];
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.resource.data.uid == userId
        && (
          isAdmin()
          || (
            request.auth.uid == userId
            && request.resource.data.email == request.auth.token.email
            && (
              request.resource.data.role == "staff"
              || (isBootstrapAdmin() && request.resource.data.role == "admin")
            )
          )
        );

      // Active Purchasing users may read the internal user directory so they
      // can select an administrator or Student Assistant in Messages.
      allow read: if signedIn()
        && (request.auth.uid == userId || isAdmin() || isActive());

      allow update: if isAdmin()
        || (
          isBootstrapAdmin()
          && request.auth.uid == userId
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == "admin"
          && request.resource.data.active == true
        )
        || (
          isActive()
          && request.auth.uid == userId
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && request.resource.data.active == resource.data.active
        );

      allow delete: if false;

      // Read-only access to records from the first personal version so the
      // updated app can copy them into the new system-wide document register.
      match /documents/{legacyDocumentId} {
        allow read: if signedIn()
          && (request.auth.uid == userId || isAdmin());
        allow write: if false;

        match /routes/{legacyRouteId} {
          allow read: if signedIn()
            && (request.auth.uid == userId || isAdmin());
          allow write: if false;
        }
      }
    }

    match /documents/{documentId} {
      allow create: if isActive()
        && request.resource.data.ownerUid is string
        && (isAdmin() || request.resource.data.ownerUid == request.auth.uid);

      allow read: if isActive()
        && (isAdmin() || resource.data.ownerUid == request.auth.uid);

      allow update: if isActive()
        && (isAdmin() || resource.data.ownerUid == request.auth.uid)
        && request.resource.data.ownerUid == resource.data.ownerUid;

      // Documents use soft delete/archive so the audit trail is preserved.
      allow delete: if false;

      match /routes/{routeId} {
        allow read: if isActive()
          && (
            isAdmin()
            || get(/databases/$(database)/documents/documents/$(documentId)).data.ownerUid == request.auth.uid
          );

        allow create: if isActive()
          && request.resource.data.documentId == documentId
          && request.resource.data.createdByUid == request.auth.uid
          && (
            isAdmin()
            || get(/databases/$(database)/documents/documents/$(documentId)).data.ownerUid == request.auth.uid
          );

        allow update: if false;

        allow delete: if false;
      }
    }

    match /conversations/{conversationId} {
      allow create: if isActive()
        && request.resource.data.participantUids is list
        && request.resource.data.participantUids.size() == 2
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.lastSenderUid == request.auth.uid;

      allow read: if isActive()
        && request.auth.uid in resource.data.participantUids;

      allow update: if isActive()
        && request.auth.uid in resource.data.participantUids
        && request.resource.data.participantUids == resource.data.participantUids
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isActive()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids;

        allow create: if isActive()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.recipientUid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantUids
          && request.resource.data.recipientUid != request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 3000;

        // Only the recipient may mark a message as read. Message text and
        // sender information cannot be edited after sending.
        allow update: if isActive()
          && resource.data.recipientUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readAt"]);

        allow delete: if false;
      }
    }

    match /activityLogs/{activityId} {
      allow create: if isActive()
        && request.resource.data.actorUid == request.auth.uid;

      allow read: if isAdmin()
        || (isActive() && resource.data.actorUid == request.auth.uid);

      allow update, delete: if false;
    }

  }
}
